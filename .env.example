# Anchor (Profile > API Token)
ANCHOR_BASE_URL=https://anchor.example.com
ANCHOR_API_TOKEN=
ANCHOR_WEB_URL=https://anchor.example.com
ANCHOR_TIMEOUT_SECONDS=15

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT_SECONDS=15
TELEGRAM_MAX_RETRIES=3

# Digest and scheduling
TIMEZONE=America/Bahia
MORNING_DIGEST_ENABLED=true
MORNING_DIGEST_TIME=08:00
EVENING_DIGEST_ENABLED=true
EVENING_DIGEST_TIME=17:00
UPCOMING_DAYS=3

# Optional OpenAI-compatible focus recommendation
LLM_ENABLED=false
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=20
LLM_INCLUDE_DESCRIPTIONS=false

# Runtime
LOG_LEVEL=INFO
DRY_RUN=false
HEARTBEAT_PATH=/tmp/task-digest/heartbeat
HEARTBEAT_INTERVAL_SECONDS=20
HEARTBEAT_MAX_AGE_SECONDS=90
SETTINGS_DATABASE_PATH=./data/task-digest.sqlite3
